# ============================================================================
# API Keys — copy this file to `.env` and fill in keys as you obtain them.
# ============================================================================
# The pipeline degrades gracefully: sources without keys emit a warning and
# metrics dependent on them are marked N/A in the output.
# ============================================================================

# --- REQUIRED ---
# CoinGecko Demo (free) — price / MC / FDV / supply / 365d historical market_chart
# Get a free demo key: https://www.coingecko.com/en/api/pricing  →  "Get Demo API Key"
COINGECKO_API_KEY=

# CoinDesk Data (free) — historical supply with breakdown (issued/burned/staked/locked/future)
# This is the primary source for inflation, burns, staking penetration metrics.
# Sign up: https://developers.coindesk.com/
COINDESK_API_KEY=

# Dune Analytics (free, 2,500 queries/month) — flagship on-chain queries
# Used for: true age-based dormancy, project-specific buybacks, holder counts.
# Sign up: https://dune.com/settings/api
DUNE_API_KEY=

# Etherscan (free) — top-holder concentration on Ethereum
# Sign up: https://etherscan.io/apis
ETHERSCAN_API_KEY=

# --- OPTIONAL: per-chain Etherscan-family keys ---
# Only fill these if your peer set includes tokens native to these L2s.
ARBISCAN_API_KEY=
BASESCAN_API_KEY=
OPTIMISTIC_ETHERSCAN_API_KEY=
